{
    "name": "pathway-academy-toolkit",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "npm run dev:planner",
        "dev:all": "node scripts/dev-staggered.js",
        "dev:up": "node scripts/dev-background-start.js",
        "dev:down": "node scripts/dev-background-stop.js",
        "dev:status": "node scripts/dev-background-status.js",
        "dev:planner": "cross-env NODE_OPTIONS=--max-old-space-size=1024 npm -w apps/esl-planner run dev",
        "dev:essay": "cross-env NODE_OPTIONS=--max-old-space-size=1024 npm -w apps/essay-lab run dev",
        "dev:nature": "node scripts/dev-nature.js",
        "dev:ops": "cross-env NODE_OPTIONS=--max-old-space-size=1024 npm -w apps/rednote-ops run dev",
        "dev:edu": "cross-env NODE_OPTIONS=--max-old-space-size=1024 npm -w apps/edu-hub run dev",
        "dev:student": "cross-env NODE_OPTIONS=--max-old-space-size=1024 npm -w apps/student-portal run dev",
        "scan": "node scripts/scan-all-apps.js npm run scan:default",
        "scan:default": "npm run build",
        "scan:pw": "node scripts/scan-all-apps.js npx playwright test",
        "test:scan": "node scripts/scan-all-apps.js",
        "check:compat-shells": "node scripts/check-compat-shells.js",
        "dev:nlm": "python scripts/nlm-proxy.py",
        "nlm": "node scripts/notebooklm-one-click.js",
        "nlm:go": "node scripts/notebooklm-one-click.js",
        "nlm:pick": "node scripts/notebooklm-pick.js",
        "nlm:folder-pick": "node scripts/notebooklm-drive-folder-picker.js",
        "nlm:bootstrap-level-notebooks": "node scripts/notebooklm-bootstrap-level-notebooks.js",
        "nlm:write-level-mapping": "node scripts/notebooklm-write-level-mapping.js",
        "nlm:seed-drive-manifest": "node scripts/notebooklm-seed-drive-manifest.js",
        "nlm:import-drive-sources": "node scripts/notebooklm-import-drive-sources.js",
        "nlm:bulk-import-drive": "node scripts/notebooklm-bulk-import-drive.js",
        "nlm:sync-level-kb": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/notebooklm-sync-level-kb.ps1",
        "nlm:sync": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/notebooklm-sync-level-kb.ps1",
        "records:backup": "node scripts/records-backup.js",
        "records:restore": "node scripts/records-restore.js",
        "audit:esl-storage": "node scripts/audit-esl-storage-alignment.js",
        "dedupe:esl-lessons": "node scripts/dedupe-esl-lessons.js",
        "build:planner": "npm -w apps/esl-planner run build",
        "build:essay": "npm -w apps/essay-lab run build",
        "build:nature": "npm -w apps/nature-compass run build",
        "build:ops": "npm -w apps/rednote-ops run build",
        "build:edu": "npm -w apps/edu-hub run build",
        "build:student": "npm -w apps/student-portal run build",
        "build:apps": "node scripts/build-staggered.js",
        "build": "node scripts/build-staggered.js && node scripts/build-landing.js",
        "typecheck": "npm run check:compat-shells && npm run typecheck:apps",
        "ci:verify": "npm run check:compat-shells && npm run typecheck:apps && npm run build",
        "typecheck:apps": "node scripts/typecheck-apps.js"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.1",
        "@types/node": "^22.14.0",
        "@vitejs/plugin-react": "^5.0.4",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "tailwindcss": "^4.2.1",
        "tsx": "^4.21.0",
        "typescript": "~5.8.2",
        "vite": "^6.2.0"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.98.0",
        "@tanstack/react-query": "^5.90.21",
        "@types/dompurify": "^3.0.5",
        "dompurify": "^3.3.2",
        "dotenv": "^17.3.1",
        "localforage": "^1.10.0",
        "lucide-react": "^0.563.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "zustand": "^5.0.11"
    }
}

{
    "name": "pathway-academy-toolkit",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "dev": "cross-env NODE_OPTIONS=\"--max-old-space-size=2048\" concurrently -n planner,essay,nature,ops,edu,student -c cyan,green,yellow,magenta,blue,white \"npm run dev:planner\" \"npm run dev:essay\" \"npm run dev:nature\" \"npm run dev:ops\" \"npm run dev:edu\" \"npm run dev:student\"",
        "dev:planner": "npm -w apps/esl-planner run dev",
        "dev:essay": "npm -w apps/essay-lab run dev",
        "dev:nature": "npm -w apps/nature-compass run dev",
        "dev:ops": "npm -w apps/rednote-ops run dev",
        "dev:edu": "npm -w apps/edu-hub run dev",
        "dev:student": "npm -w apps/student-portal run dev",
        "build:planner": "npm -w apps/esl-planner run build",
        "build:essay": "npm -w apps/essay-lab run build",
        "build:nature": "npm -w apps/nature-compass run build",
        "build:ops": "npm -w apps/rednote-ops run build",
        "build:edu": "npm -w apps/edu-hub run build",
        "build:student": "npm -w apps/student-portal run build",
        "build:apps": "npm run build:planner && npm run build:essay && npm run build:nature && npm run build:ops && npm run build:edu && npm run build:student",
        "build": "npm run build:apps && node scripts/build-landing.js"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.1",
        "@types/node": "^22.14.0",
        "@vitejs/plugin-react": "^5.0.4",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "tailwindcss": "^4.2.1",
        "typescript": "~5.8.2",
        "vite": "^6.2.0"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.98.0",
        "localforage": "^1.10.0",
        "lucide-react": "^0.563.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "zustand": "^5.0.11"
    }
}
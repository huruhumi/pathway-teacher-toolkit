{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/planner/(.*)",
      "destination": "/planner/index.html"
    },
    {
      "source": "/essay-lab/(.*)",
      "destination": "/essay-lab/index.html"
    },
    {
      "source": "/nature-compass/(.*)",
      "destination": "/nature-compass/index.html"
    },
    {
      "source": "/rednote-ops/(.*)",
      "destination": "/rednote-ops/index.html"
    },
    {
      "source": "/edu-hub/(.*)",
      "destination": "/edu-hub/index.html"
    },
    {
      "source": "/student-portal/(.*)",
      "destination": "/student-portal/index.html"
    }
  ]
}
